# Database (Neon / Vercel Postgres / local Postgres)
POSTGRES_URL=postgresql://user:password@host:5432/job_finder

# Resume (required on first agent cycle)
RESUME_TEXT="Paste your resume text here. Optional lines: Skills: TypeScript, React | Titles: Software Engineer | Locations: New York"

# Adzuna job API — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# Google Gemini — https://aistudio.google.com/apikey
# Used for gemini-2.5-flash (param refinement) + gemini-embedding-001 (scoring)
GOOGLE_GENERATIVE_AI_API_KEY=

# Inngest — https://www.inngest.com/docs/deploy/vercel
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Vercel Cron auth (set in Vercel dashboard; sent as Authorization: Bearer)
CRON_SECRET=

# Optional: protect pause/resume API
ADMIN_SECRET=
