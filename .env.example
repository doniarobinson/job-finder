# Neon Postgres (Vercel Marketplace → Storage → Neon sets these automatically)
# https://neon.com/docs/guides/vercel-managed-integration
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Direct connection for drizzle-kit (db:push / migrations). Optional locally if pooled URL works.
DATABASE_URL_UNPOOLED=

# Legacy Vercel Postgres alias (optional fallback)
# POSTGRES_URL=

# Resume (required on first agent cycle)
RESUME_TEXT="Paste your resume text here. Optional lines: Skills: TypeScript, React | Titles: Software Engineer | Locations: New York"

# Adzuna job API — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# Google Gemini — https://aistudio.google.com/apikey
# Used for gemini-2.5-flash (parameter refinement) + gemini-embedding-001 (scoring)
GOOGLE_GENERATIVE_AI_API_KEY=

# Inngest — https://www.inngest.com/docs/deploy/vercel
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Vercel Cron auth (set in Vercel dashboard; sent as Authorization: Bearer)
CRON_SECRET=

# Optional: protect pause/resume API
ADMIN_SECRET=
